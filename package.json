{
  "name": "modalete",
  "version": "0.4.0",
  "description": "A lightweight Web Component modal dialog with Promise-based API",
  "type": "module",
  "main": "./dist/modalete.umd.cjs",
  "module": "./dist/modalete.js",
  "types": "./dist/modalete.d.ts",
  "exports": {
    ".": {
      "import": "./dist/modalete.js",
      "require": "./dist/modalete.umd.cjs",
      "types": "./dist/modalete.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "web-components",
    "modal",
    "dialog",
    "typescript",
    "custom-elements",
    "shadow-dom"
  ],
  "author": "ifjtoledo",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}